{
  "expo": {
    "name": "Cogni Klinik",
    "slug": "cogni-klinik",
    "scheme": "cogni-klinik",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cognivault.cogniklinik",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Cogni Klinik, kliniğin yerel ve KVKK uyumlu sunucusuna bağlanmak için yerel ağ erişimi kullanır.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "package": "com.cognivault.cogniklinik",
      "adaptiveIcon": {
        "backgroundColor": "#E3F1ED",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
