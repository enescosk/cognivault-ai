# ============================================================================
# CogniVault AI — Environment Variables Template
# ============================================================================
# Bu dosyayı kopyala: `cp .env.example .env` ve gerçek değerlerle doldur.
#
# .env DOSYASI ASLA git'e EKLENMEMELI (.gitignore zaten içeriyor).
# Production'da bu değişkenler container/secret manager üzerinden geçirilmeli;
# diske `.env` koymak yerine env injection tercih edin.
# ============================================================================

# ── Environment ─────────────────────────────────────────────────────────────
# development | staging | production
# Production'da güvenlik fail-fast'leri etkinleşir:
#   - zayıf JWT_SECRET reddedilir (uygulama başlamaz)
#   - SEED_DEMO_DATA=true olsa bile demo data oluşturulmaz
#   - webhook imza doğrulaması zorunlu olur
ENVIRONMENT=development

# ── Database ────────────────────────────────────────────────────────────────
# Dev için SQLite varsayılan. Prod için: postgresql+psycopg://user:pass@host:5432/db
DATABASE_URL=sqlite:///data/cognivault.db
POSTGRES_DB=cognivault
POSTGRES_USER=cognivault
POSTGRES_PASSWORD=cognivault

# ── Security ────────────────────────────────────────────────────────────────
# JWT_SECRET production'da en az 32 karakter, yüksek entropili olmalı.
# Güçlü secret üret:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Aşağıdaki "replace-me" production'da uygulamayı BAŞLATMAZ (fail-fast).
JWT_SECRET=replace-me

# Demo data — production'da false. Geliştirme/test için true.
SEED_DEMO_DATA=true

# Webhook imza doğrulaması — production'da zaten zorunlu (kod zorlar).
CLINICAL_WEBHOOK_SIGNATURE_REQUIRED=false

# ── LLM (OpenAI) ────────────────────────────────────────────────────────────
# UYARI: Klinik PHI verisi için standart OpenAI API'si HIPAA-uyumsuz.
# Production'da Azure OpenAI Service (BAA imzalı) tercih et.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# ── LLM (Anthropic) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_INTENT_MODEL=claude-haiku-4-5-20251001
# "auto" tries Anthropic first when key present, then OpenAI, then local rules
PREFERRED_AGENT_PROVIDER=auto
CLINICAL_AI_ENABLED=false
CLINICAL_EXTERNAL_AI_ALLOWED=false
VOICE_EXTERNAL_ENABLED=false
CLINICAL_DEFAULT_CLINIC_SLUG=demo-klinik
CLINICAL_AUTO_REPLY_THRESHOLD=0.90
CLINICAL_SHADOW_THRESHOLD=0.75

# ── Twilio (WhatsApp + Voice) ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Meta (WhatsApp Cloud API) ───────────────────────────────────────────────
# META_APP_SECRET X-Hub-Signature-256 doğrulaması için zorunlu (prod).
META_VERIFY_TOKEN=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_APP_SECRET=

# ── Intelligence / External Discovery ───────────────────────────────────────
INTELLIGENCE_EXTERNAL_ENABLED=false
GOOGLE_PLACES_API_KEY=

# ── CORS ────────────────────────────────────────────────────────────────────
# Production'da sadece kendi frontend domain'in. Asla "*" KULLANMA.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5200,http://127.0.0.1:5200,http://localhost:8080

# ── Frontend ────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api

# ── E-posta (opsiyonel) ─────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cognivault.local

# ── SMS (randevu onayları) ──────────────────────────────────────────────────
# mock: konsol simülasyonu (varsayılan). netgsm: gerçek gönderim — üç alan da
# zorunlu (Netgsm usercode/password + operatör onaylı başlık). Kimlik eksikse
# uygulama yüksek sesle loglayıp mock'a düşer; /health/ready "fail" gösterir.
SMS_PROVIDER=mock
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=

# ── Çoklu kiracı kanal eşlemesi ─────────────────────────────────────────────
# true: aranan numara/WABA kimliği hiçbir kliniğe bağlı değilse webhook REDDEDİLİR
# (çoklu klinik pilotu). false: demo default kliniğe düşer (tek klinik).
CLINICAL_CHANNEL_BINDING_STRICT=false
